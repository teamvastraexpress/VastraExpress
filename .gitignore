# ============================================================
# ROOT .gitignore — Vastra Express Monorepo
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js Build Output ───────────────────────────────────
.next/
out/
.turbo/

# ─── Expo / React Native Build Output ───────────────────────
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ─── NestJS / Backend Build Output ──────────────────────────
/vastra-express-backend/dist/
/vastra-express-backend/build/

# ─── Production Builds ──────────────────────────────────────
build/

# ─── TypeScript Build Info ──────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Environment Variables ──────────────────────────────────
# Keep .env.example files — ignore actual secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ─── Testing & Coverage ─────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── IDE / Editor ───────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project
.project
.classpath
.c9/
*.launch
.settings/

# ─── Prisma Generated ───────────────────────────────────────
generated/prisma/

# ─── React Native / Expo Native Folders ─────────────────────
/ios/
/android/
.kotlin/

# ─── Certificates & Keys ────────────────────────────────────
*.pem
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ─── Vercel ─────────────────────────────────────────────────
.vercel

# ─── Temp ───────────────────────────────────────────────────
.temp/
.tmp/
*.pid
*.seed
*.pid.lock

# ─── Misc ───────────────────────────────────────────────────
.metro-health-check*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Backend API base URL (no trailing slash)
# Leave blank to auto-detect the host from Expo when running on a phone.
# For a manual override, use your LAN IP (e.g. http://192.168.1.100:3000/api)
# For Android emulator, use http://10.0.2.2:3000/api
# For iOS simulator, use http://localhost:3000/api
EXPO_PUBLIC_API_URL=

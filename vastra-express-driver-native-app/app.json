{
  "expo": {
    "name": "Vastra Express Driver",
    "slug": "vastra-express-driver-native-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vastradriver",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/vastra-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vastraexpress.driver"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "package": "com.vastraexpress.driver"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://vastra-xpress-production.up.railway.app/api",
      "router": {},
      "eas": {
        "projectId": "a1deebb9-cb61-4f84-9000-9fa00af6fc5f"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "yorokobi_kujur"
  }
}

# ============================================================
# .gitattributes — Vastra Express Monorepo
# Normalize line endings for cross-platform consistency
# ============================================================

# Default: auto-detect and normalize
* text=auto

# Explicitly declare text files to use LF on checkout
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.prisma    text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
*.env       text eol=lf
*.gitignore text eol=lf

# Windows shell scripts — keep CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.zip       binary
*.gz        binary
*.pdf       binary

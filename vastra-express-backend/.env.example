# ============================================
# VASTRA EXPRESS - ENVIRONMENT CONFIGURATION
# ============================================

# ----------------
# Application
# ----------------
NODE_ENV=development
PORT=3000

# ----------------
# Database
# ----------------

# ----------------
# Authentication & Security
# ----------------
# CRITICAL: Generate a cryptographically secure secret with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This produces a 128-character hex string (64 bytes)
JWT_SECRET="GENERATE_WITH_CRYPTO_RANDOM_BYTES_64_NEVER_USE_THIS_PLACEHOLDER"

# JWT Expiry (in days)
JWT_EXPIRY=7d

# ----------------
# SMS Provider (MSG91)
# ----------------
# Get your API key from: https://control.msg91.com/
# Leave empty for development (will log OTPs to console)
MSG91_AUTH_KEY=

# MSG91 Template ID for OTP
MSG91_TEMPLATE_ID=

# ----------------
# Firebase (Phone Auth & Push Notifications)
# ----------------
# Firebase Admin SDK Service Account (for authentication and notifications)
# Generate from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Copy the entire JSON content (not the file path) into this variable
# Format: {"type": "service_account", "project_id": "...", ...}
# CRITICAL: Keep this secret - do not commit to version control
FIREBASE_SERVICE_ACCOUNT={}

# Alternative: Path-based configuration (uncomment to use file path instead)
# Will load JSON from specified file if FIREBASE_SERVICE_ACCOUNT is empty
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json

# Firebase Phone Auth Configuration
# Enable phone number authentication for users
EXPOSE_OTP_IN_RESPONSE=true

# ----------------
# Payment Gateway (Razorpay)
# ----------------
# Get your keys from: https://dashboard.razorpay.com/
# Use test keys for development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ----------------
# Redis (Coming Day 3)
# ----------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------
# Rate Limiting
# ----------------
# Global rate limit: requests per time window
THROTTLE_TTL=900000     # 15 minutes in milliseconds
THROTTLE_LIMIT=100      # Max requests per window

# OTP-specific rate limits
OTP_SEND_LIMIT=3        # Max OTP send requests per minute
OTP_VERIFY_LIMIT=5      # Max OTP verify requests per minute

# ----------------
# OTP Configuration
# ----------------
OTP_EXPIRY=300          # OTP expiry in seconds (5 minutes)
OTP_MAX_ATTEMPTS=3      # Maximum verification attempts per OTP
OTP_COOLDOWN=60         # Cooldown between OTP requests in seconds
# TEMPORARY (beta only): force include OTP in auth API responses for web toast notifications.
# If this variable is not set, backend auto-exposes OTP whenever MSG91 credentials are missing.
EXPOSE_OTP_IN_RESPONSE=false

# ----------------
# CORS Origins
# ----------------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004
# Backward-compatible alias (supported in code): CORS_ORIGINS=

# ----------------
# Logging
# ----------------
LOG_LEVEL=debug         # debug | info | warn | error

# ----------------
# File Upload (Coming Day 10)
# ----------------
MAX_FILE_SIZE=5242880   # 5MB in bytes
UPLOAD_PATH=./uploads

# ----------------
# Admin Credentials (Coming Day 6)
# ----------------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ============================================
# NOTES
# ============================================
# 1. Copy this file to .env and fill in your values
# 2. NEVER commit .env to version control
# 3. Keep production secrets secure and rotate regularly
# 4. Use strong passwords (min 12 chars, mixed case, numbers, symbols)
# 5. For production, use environment-specific values
# ============================================

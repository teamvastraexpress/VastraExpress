# ============================================
# VASTRA EXPRESS - ENVIRONMENT CONFIGURATION
# ============================================

# ----------------
# Application
# ----------------
NODE_ENV=development
PORT=3000

# ----------------
# Database
# ----------------
# DATABASE_URL="mysql://user:pass@host:port/db"

# ----------------
# Authentication & Security
# ----------------
# CRITICAL: Generate a cryptographically secure secret with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERATE_WITH_CRYPTO_RANDOM_BYTES_64"
JWT_EXPIRY=7d

# ----------------
# Email OTP Service (Indiegram API)
# ----------------
EMAIL_OTP_SEND_URL="https://email.indiegrampublications.com/send_email.php"
EMAIL_OTP_AUTH_TOKEN="MY_SECRET_KEY_123"

# ----------------
# Rate Limiting
# ----------------
THROTTLE_TTL=900000
THROTTLE_LIMIT=100

# ----------------
# CORS Origins
# ----------------
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ----------------
# File Upload
# ----------------
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
